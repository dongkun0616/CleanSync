CREATE DATABASE IF NOT EXISTS clean_sync
DEFAULT CHARACTER SET utf8mb4
DEFAULT COLLATE utf8mb4_general_ci;

USE clean_sync;

# 홈 화면용 최신 상태 테이블
CREATE TABLE home_status (
    id INT NOT NULL AUTO_INCREMENT,
    DUST_PM10 DECIMAL(6,2) NOT NULL DEFAULT 0.00,
    DUST_PM25 DECIMAL(6,2) NOT NULL DEFAULT 0.00,
    TEMP DECIMAL(5,2) NOT NULL DEFAULT 0.00,
    HUM DECIMAL(5,2) NOT NULL DEFAULT 0.00,
    NOS DECIMAL(5,2) NOT NULL DEFAULT 0.00,
    CREATE_AT DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    DST VARCHAR(20) NULL DEFAULT NULL,
    CST VARCHAR(20) NULL DEFAULT NULL,
    CS INT NULL DEFAULT NULL,
    WIFI_COUNT INT NOT NULL DEFAULT 0,
    PRIMARY KEY (id)
);

# 통계 화면용 이력 테이블
CREATE TABLE statistics_logs (
    id INT NOT NULL AUTO_INCREMENT,
    DUST_PM10 DECIMAL(6,2) NOT NULL DEFAULT 0.00,
    DUST_PM25 DECIMAL(6,2) NOT NULL DEFAULT 0.00,
    TEMP DECIMAL(5,2) NOT NULL DEFAULT 0.00,
    HUM DECIMAL(5,2) NOT NULL DEFAULT 0.00,
    NOS DECIMAL(5,2) NOT NULL DEFAULT 0.00,
    DST VARCHAR(20) NULL DEFAULT NULL,
    CREATE_AT DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (id)
);

# 설정 화면용 테이블
CREATE TABLE app_settings (
    setting_id INT NOT NULL AUTO_INCREMENT,
    alert_dust_threshold DECIMAL(6,2) NOT NULL DEFAULT 35.00,
    alert_noise_threshold DECIMAL(5,2) NOT NULL DEFAULT 65.00,
    dust_alert_enabled TINYINT(1) NOT NULL DEFAULT 1,
    noise_alert_enabled TINYINT(1) NOT NULL DEFAULT 1,
    theme_mode VARCHAR(10) NULL DEFAULT 'Light',
    service_info VARCHAR(50) NULL DEFAULT 'Clean-Sync',
    updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    CST VARCHAR(20) NULL DEFAULT NULL,
    CS INT NULL DEFAULT NULL,
    PRIMARY KEY (setting_id)
);
